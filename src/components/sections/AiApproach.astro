---
import { type Locale, getDict } from '@i18n/ui';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<section id="ai" class="scroll-mt-20 py-20 sm:py-28">
  <div class="container-x">
    <div
      class="glow-bg relative overflow-hidden rounded-3xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-6 py-14 sm:px-12 sm:py-16"
    >
      <div class="grid-pattern pointer-events-none absolute inset-0 -z-10 opacity-40"></div>

      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
          {t.ai.kicker}
        </p>
        <h2 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
          {t.ai.title}
        </h2>
        <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.ai.subtitle}</p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {
          t.ai.points.map((p, i) => (
            <div
              class="reveal rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-base)]/40 p-6"
              style={`transition-delay:${i * 80}ms`}
            >
              <div class="font-[family-name:var(--font-display)] text-3xl font-bold text-gradient">
                0{i + 1}
              </div>
              <h3 class="mt-3 text-lg font-semibold">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">{p.desc}</p>
            </div>
          ))
        }
      </div>

      <p class="reveal mt-10 text-center text-sm text-[color:var(--color-ink-faint)]">
        {t.ai.note}
      </p>
    </div>
  </div>
</section>
