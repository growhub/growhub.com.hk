---
import AiApproach from '@feature/ai-approach';
import Capabilities from '@feature/capabilities';
import Company from '@feature/company';
import ContactCta from '@feature/contact-cta';
import Faq from '@feature/faq';
import Hero from '@feature/hero';
import News from '@feature/news';
import Services from '@feature/services';
import Works from '@feature/works';
import { getDict } from '@i18n/ui';
import BaseLayout from '@layouts/base-layout';
import type { HomePageProps } from './types';

const { lang } = Astro.props as HomePageProps;
const t = getDict(lang);
---

<BaseLayout lang={lang} route="/" title={t.meta.home_title} description={t.meta.home_desc}>
  <Hero lang={lang} />
  <Services lang={lang} />
  <Capabilities lang={lang} />
  <AiApproach lang={lang} />
  <Works lang={lang} />
  <Company lang={lang} />
  <News lang={lang} />
  <Faq lang={lang} />
  <ContactCta lang={lang} />
</BaseLayout>
