---
import { getDict } from '@i18n/ui';
import type { AiApproachProps } from './types';

const { lang } = Astro.props as AiApproachProps;
const t = getDict(lang);
---

<section id="ai" class="scroll-mt-20 py-20 sm:py-28">
  <div class="container-x">
    <div
      class="glow-bg relative overflow-hidden rounded-3xl px-6 py-14 text-white sm:px-12 sm:py-20"
      style="background:linear-gradient(135deg,#1e1b4b 0%,#0f172a 55%,#0c4a6e 130%);--glow-c1:rgba(99,102,241,0.5);--glow-c2:rgba(34,211,238,0.4);"
    >
      <div class="grid-pattern pointer-events-none absolute inset-0 -z-10 opacity-[0.18]"></div>

      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold tracking-[0.2em] text-[#38bdf8]">
          {t.ai.kicker}
        </p>
        <h2 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {t.ai.title}
        </h2>
        <p class="mt-4 text-white/70">{t.ai.subtitle}</p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {
          t.ai.points.map((p, i) => (
            <div
              class="reveal rounded-2xl border border-white/10 bg-white/[0.06] p-6 backdrop-blur-sm transition-colors hover:border-white/25 hover:bg-white/[0.09]"
              style={`transition-delay:${i * 80}ms`}
            >
              <div
                class="font-[family-name:var(--font-display)] text-3xl font-bold"
                style="background:linear-gradient(100deg,#38bdf8,#818cf8 70%);-webkit-background-clip:text;background-clip:text;color:transparent;"
              >
                0{i + 1}
              </div>
              <h3 class="mt-3 text-lg font-semibold text-white">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{p.desc}</p>
            </div>
          ))
        }
      </div>

      <p class="reveal mt-10 text-center text-sm text-white/55">
        {t.ai.note}
      </p>
    </div>
  </div>
</section>
