---
import { getDict } from '@i18n/ui';
import type { NewsProps } from './types';

const { lang } = Astro.props as NewsProps;
const t = getDict(lang);
---

<section id="news" class="scroll-mt-20 py-8 sm:py-12">
  <div class="container-x">
    <div class="reveal mb-8 flex items-baseline gap-4">
      <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
        {t.news.kicker}
      </p>
      <h2 class="font-[family-name:var(--font-display)] text-xl font-bold tracking-tight">
        {t.news.title}
      </h2>
    </div>

    <div class="reveal space-y-3">
      {
        t.news.items.map((item) => (
          <article class="card flex flex-col gap-3 p-6 sm:flex-row sm:items-start sm:gap-6">
            <time class="inline-flex shrink-0 items-center gap-1.5 self-start rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface-2)] px-3 py-1 text-xs font-semibold text-[color:var(--color-brand-2)]">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="4" width="18" height="17" rx="2" />
                <path d="M8 2v4M16 2v4M3 10h18" />
              </svg>
              {item.date}
            </time>
            <div>
              <h3 class="font-semibold text-[color:var(--color-ink)]">{item.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">
                {item.desc}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
