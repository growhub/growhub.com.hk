---
import { getDict } from '@i18n/ui';
import type { FaqProps } from './types';

const { lang } = Astro.props as FaqProps;
const t = getDict(lang);

// FAQPage structured data (AEO/GEO). Built from the same dictionary content.
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<section id="faq" class="scroll-mt-20 bg-[color:var(--color-surface-2)]/40 py-20 sm:py-28">
  <div class="container-x">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[color:var(--color-brand-2)]">
        {t.faq.kicker}
      </p>
      <h2
        class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl"
      >
        {t.faq.title}
      </h2>
      <p class="mt-4 leading-relaxed text-[color:var(--color-ink-muted)]">{t.faq.subtitle}</p>
    </div>

    <div class="reveal mx-auto mt-12 max-w-3xl space-y-4">
      {
        t.faq.items.map((item, i) => (
          <details class="card group p-0" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-6 font-semibold text-[color:var(--color-ink)] [&::-webkit-details-marker]:hidden">
              <span>{item.q}</span>
              <svg
                class="shrink-0 text-[color:var(--color-brand-2)] transition-transform duration-300 group-open:rotate-180"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="px-6 pb-6 leading-relaxed text-[color:var(--color-ink-muted)]">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
