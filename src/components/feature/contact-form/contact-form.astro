---
import { getDict } from '@i18n/ui';
import ContactForm from './form.tsx';
import { buildContactAction } from './hooks';
import type { ContactFormProps, ContactLabels } from './types';

const { lang } = Astro.props as ContactFormProps;
const t = getDict(lang);
const action = buildContactAction(lang);

// Cloudflare Turnstile — optional. When PUBLIC_TURNSTILE_SITE_KEY is unset
// (e.g. local dev), the widget is skipped and the form still works.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';

const labels: ContactLabels = {
  name: t.contact.name,
  company: t.contact.company,
  email: t.contact.email,
  content: t.contact.content,
  submit: t.contact.submit,
  sending: t.contact.sending,
  privacyNote: t.contact.privacy_note,
  emailPlaceholder: 'example@sample.com',
  errors: {
    name: t.contact.errors.name,
    email: t.contact.errors.email,
    content: t.contact.errors.content,
    turnstile: t.contact.errors.turnstile,
    generic: t.contact.errors.generic,
  },
};
---

{/* The validated React island submits via AJAX to the Cloudflare Pages
    Function at /api/contact, which verifies Turnstile and emails the message. */}
<ContactForm client:load labels={labels} action={action} siteKey={turnstileSiteKey} />
