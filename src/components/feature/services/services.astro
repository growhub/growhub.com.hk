---
import { getDict } from '@i18n/ui';
import { serviceImages as images } from './constants';
import type { ServicesProps } from './types';

const { lang } = Astro.props as ServicesProps;
const t = getDict(lang);
---

<section id="services" class="scroll-mt-20 py-20 sm:py-28">
  <div class="container-x">
    <div class="flex items-end justify-between gap-6">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
          {t.services.kicker}
        </p>
        <h2 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
          {t.services.title}
        </h2>
        <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.services.subtitle}</p>
      </div>

      <!-- carousel controls (desktop) -->
      <div class="hidden shrink-0 gap-2 lg:flex">
        <button
          type="button"
          data-services-prev
          aria-label="Previous"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-[color:var(--color-border)] text-[color:var(--color-ink-muted)] transition-colors hover:border-[color:var(--color-brand-2)] hover:text-[color:var(--color-brand)]"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button
          type="button"
          data-services-next
          aria-label="Next"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-[color:var(--color-border)] text-[color:var(--color-ink-muted)] transition-colors hover:border-[color:var(--color-brand-2)] hover:text-[color:var(--color-brand)]"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="reveal mt-12">
      <div
        data-services-track
        class="no-scrollbar -mx-5 flex snap-x snap-mandatory scroll-px-5 gap-5 overflow-x-auto scroll-smooth px-5 pb-4"
      >
        {
          t.services.items.map((item, i) => (
            <article class="card flex w-[300px] shrink-0 snap-start flex-col overflow-hidden p-0 sm:w-[360px]">
              <img
                src={images[i]}
                alt=""
                width="800"
                height="600"
                class="aspect-[16/10] w-full object-cover"
              />
              <div class="flex flex-1 flex-col p-6">
                <h3 class="text-lg font-semibold">{item.name}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">
                  {item.desc}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-[11px] text-[color:var(--color-ink-faint)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector<HTMLElement>('[data-services-track]');
  if (track) {
    const step = () => {
      const card = track.querySelector<HTMLElement>('article');
      return card ? card.offsetWidth + 20 : track.clientWidth;
    };
    document
      .querySelector('[data-services-prev]')
      ?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    document
      .querySelector('[data-services-next]')
      ?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
  }
</script>
