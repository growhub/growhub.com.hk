---
import { getDict } from '@i18n/ui';
import { serviceIconPaths as icons } from './constants';
import type { ServicesProps } from './types';

const { lang } = Astro.props as ServicesProps;
const t = getDict(lang);
---

<section id="services" class="scroll-mt-20 py-20 sm:py-28">
  <div class="container-x">
    <div class="reveal max-w-2xl">
      <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
        {t.services.kicker}
      </p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
        {t.services.title}
      </h2>
      <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.services.subtitle}</p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.services.items.map((item, i) => (
          <article class="card reveal flex flex-col p-6" style={`transition-delay:${i * 70}ms`}>
            <div
              class="flex h-11 w-11 items-center justify-center rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface-2)]"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="url(#svc-grad)"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={icons[i]} />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">{item.name}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">
              {item.desc}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class="rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-[11px] text-[color:var(--color-ink-faint)]">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <!-- shared gradient for icon strokes -->
  <svg width="0" height="0" class="absolute" aria-hidden="true">
    <defs>
      <linearGradient id="svc-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#22d3ee" />
        <stop offset="100%" stop-color="#6366f1" />
      </linearGradient>
    </defs>
  </svg>
</section>
