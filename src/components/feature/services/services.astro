---
import { getDict } from '@i18n/ui';
import { serviceImages as images } from './constants';
import type { ServicesProps } from './types';

const { lang } = Astro.props as ServicesProps;
const t = getDict(lang);
---

<section id="services" class="scroll-mt-20 py-20 sm:py-28">
  <div class="container-x">
    <div class="flex items-end justify-between gap-6">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
          {t.services.kicker}
        </p>
        <h2 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
          {t.services.title}
        </h2>
        <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.services.subtitle}</p>
      </div>

      <!-- carousel controls (desktop) -->
      <div class="hidden shrink-0 gap-2 lg:flex">
        <button
          type="button"
          data-services-prev
          aria-label="Previous"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-[color:var(--color-border)] text-[color:var(--color-ink-muted)] transition-colors hover:border-[color:var(--color-brand-2)] hover:text-[color:var(--color-brand)]"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button
          type="button"
          data-services-next
          aria-label="Next"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-[color:var(--color-border)] text-[color:var(--color-ink-muted)] transition-colors hover:border-[color:var(--color-brand-2)] hover:text-[color:var(--color-brand)]"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="reveal mt-12">
      <div
        data-services-track
        class="no-scrollbar -mx-5 flex snap-x snap-mandatory scroll-px-5 gap-5 overflow-x-auto scroll-smooth px-5 pb-4"
      >
        {
          t.services.items.map((item, i) => (
            <article class="card flex w-[85%] shrink-0 snap-start flex-col overflow-hidden p-0 sm:w-[62%] lg:w-[35%]">
              <img
                src={images[i]}
                alt=""
                width="800"
                height="600"
                class="aspect-[16/10] w-full object-cover"
              />
              <div class="flex flex-1 flex-col p-6">
                <h3 class="text-lg font-semibold">{item.name}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">
                  {item.desc}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-[11px] text-[color:var(--color-ink-faint)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector<HTMLElement>('[data-services-track]');
  if (track) {
    const step = () => {
      const card = track.querySelector<HTMLElement>('article');
      return card ? card.offsetWidth + 20 : track.clientWidth;
    };
    const scrollByStep = (dir: number) => track.scrollBy({ left: dir * step(), behavior: 'smooth' });

    const prev = document.querySelector('[data-services-prev]');
    const next = document.querySelector('[data-services-next]');
    prev?.addEventListener('click', () => scrollByStep(-1));
    next?.addEventListener('click', () => scrollByStep(1));

    // --- Autoplay ---
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false;

    const tick = () => {
      if (paused) return;
      const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 4;
      if (atEnd) track.scrollTo({ left: 0, behavior: 'smooth' });
      else scrollByStep(1);
    };
    const start = () => {
      if (!reduce && timer === null) timer = setInterval(tick, 3800);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    // Pause on hover / focus / touch, and briefly after an arrow click.
    const pause = () => {
      paused = true;
    };
    const resume = () => {
      paused = false;
    };
    const resumeLater = (ms: number) => {
      paused = true;
      window.setTimeout(resume, ms);
    };
    track.addEventListener('pointerenter', pause);
    track.addEventListener('pointerleave', resume);
    track.addEventListener('focusin', pause);
    track.addEventListener('focusout', resume);
    track.addEventListener('touchstart', () => resumeLater(6000), { passive: true });
    prev?.addEventListener('click', () => resumeLater(8000));
    next?.addEventListener('click', () => resumeLater(8000));

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    // Only autoplay while the carousel is on screen.
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) start();
          else stop();
        }
      },
      { threshold: 0.25 }
    );
    io.observe(track);
  }
</script>
