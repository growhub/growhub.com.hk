---
import { getDict } from '@i18n/ui';
import { flowIcons } from './constants';
import type { FlowProps } from './types';

const { lang } = Astro.props as FlowProps;
const t = getDict(lang);
const { steps, speed } = t.flow;
---

<section id="flow" class="scroll-mt-20 bg-[color:var(--color-surface-2)]/40 py-20 sm:py-28">
  <div class="container-x">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[color:var(--color-brand-2)]">
        {t.flow.kicker}
      </p>
      <h2
        class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl"
      >
        {t.flow.title}
      </h2>
      <p class="mt-4 leading-relaxed text-[color:var(--color-ink-muted)]">{t.flow.subtitle}</p>
    </div>

    <!-- Pipeline diagram: steps connected by arrows, over an AI engine band -->
    <div class="reveal card mx-auto mt-12 max-w-5xl p-6 sm:p-8">
      <div class="flex flex-col gap-2 md:flex-row md:items-stretch md:gap-0">
        {
          steps.map((step, i) => (
            <>
              <div class="flex flex-1 flex-col items-center px-2 text-center">
                <span
                  class="flex h-14 w-14 items-center justify-center rounded-2xl text-white shadow-sm"
                  style="background-image:linear-gradient(135deg,var(--color-brand),var(--color-brand-2))"
                >
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={flowIcons[i]}
                  />
                </span>
                <span class="mt-1.5 text-[0.7rem] font-semibold text-[color:var(--color-ink-faint)]">
                  {`0${i + 1}`}
                </span>
                <h3 class="mt-1 text-sm font-bold tracking-tight text-[color:var(--color-ink)]">
                  {step.title}
                </h3>
                <p class="mt-1.5 text-xs leading-relaxed text-[color:var(--color-ink-muted)]">
                  {step.desc}
                </p>
              </div>
              {i < steps.length - 1 && (
                <div class="flex items-center justify-center py-1 text-[color:var(--color-brand-2)] md:px-1 md:pt-7">
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="rotate-90 md:rotate-0"
                  >
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </div>
              )}
            </>
          ))
        }
      </div>

      <!-- AI engine band underpinning every step -->
      <div
        class="mt-6 flex items-center justify-center gap-2 rounded-2xl px-5 py-3.5 text-center text-sm font-semibold text-white"
        style="background-image:linear-gradient(100deg,var(--color-brand),var(--color-brand-2))"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="m12 3 1.9 5.8a2 2 0 0 0 1.3 1.3L21 12l-5.8 1.9a2 2 0 0 0-1.3 1.3L12 21l-1.9-5.8a2 2 0 0 0-1.3-1.3L3 12l5.8-1.9a2 2 0 0 0 1.3-1.3Z"
          ></path>
        </svg>
        {t.flow.engine}
      </div>
    </div>

    <!-- Speed comparison -->
    <div class="reveal card mx-auto mt-8 max-w-5xl p-6 sm:p-8">
      <h3 class="font-[family-name:var(--font-display)] text-lg font-bold tracking-tight">
        {speed.title}
      </h3>
      <div class="mt-5 space-y-4">
        <div>
          <div class="flex items-baseline justify-between text-sm">
            <span class="text-[color:var(--color-ink-muted)]">{speed.traditional}</span>
            <span class="font-medium text-[color:var(--color-ink-faint)]">
              {speed.traditionalValue}
            </span>
          </div>
          <div class="mt-1.5 h-2.5 w-full rounded-full bg-[color:var(--color-surface-2)]">
            <div class="h-full w-full rounded-full bg-[color:var(--color-ink-faint)]/35"></div>
          </div>
        </div>
        <div>
          <div class="flex items-baseline justify-between text-sm">
            <span class="font-semibold text-[color:var(--color-brand)]">{speed.ai}</span>
            <span class="font-bold text-[color:var(--color-brand)]">{speed.aiValue}</span>
          </div>
          <div class="mt-1.5 h-2.5 w-full rounded-full bg-[color:var(--color-surface-2)]">
            <div
              class="h-full w-[34%] rounded-full"
              style="background-image:linear-gradient(100deg,var(--color-brand),var(--color-brand-2))"
            >
            </div>
          </div>
        </div>
      </div>
      <p class="mt-5 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">{speed.note}</p>
    </div>
  </div>
</section>
