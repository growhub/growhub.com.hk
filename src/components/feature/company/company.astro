---
import { getDict } from '@i18n/ui';
import { companyIcons } from './constants';
import { buildCompanyRows } from './hooks';
import type { CompanyProps } from './types';

const { lang } = Astro.props as CompanyProps;
const t = getDict(lang);
const rows = buildCompanyRows(lang);
---

<section id="company" class="scroll-mt-20 bg-[color:var(--color-surface-2)]/60 py-20 sm:py-28">
  <div class="container-x">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="reveal">
        <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
          {t.company.kicker}
        </p>
        <h2
          class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl"
        >
          {t.company.title}
        </h2>
      </div>

      <dl class="reveal card overflow-hidden">
        {
          rows.map((row, i) => (
            <div
              class:list={[
                'flex items-start gap-4 px-6 py-5',
                i > 0 && 'border-t border-[color:var(--color-border)]',
              ]}
            >
              <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)]">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="url(#company-grad)"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={companyIcons[i]}
                />
              </span>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-[color:var(--color-ink-faint)]">
                  {row.label}
                </dt>
                <dd class="mt-1 text-sm leading-relaxed text-[color:var(--color-ink)]">
                  {row.value}
                </dd>
              </div>
            </div>
          ))
        }
      </dl>
    </div>
  </div>

  <svg width="0" height="0" class="absolute" aria-hidden="true">
    <defs>
      <linearGradient id="company-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0284c7"></stop>
        <stop offset="100%" stop-color="#4f46e5"></stop>
      </linearGradient>
    </defs>
  </svg>
</section>
