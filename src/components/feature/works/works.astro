---
import { getDict } from '@i18n/ui';
import type { WorksProps } from './types';

const { lang } = Astro.props as WorksProps;
const t = getDict(lang);
---

<section id="works" class="scroll-mt-20 py-20 sm:py-28">
  <div class="container-x">
    <div class="reveal max-w-2xl">
      <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
        {t.works.kicker}
      </p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
        {t.works.title}
      </h2>
      <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.works.subtitle}</p>
    </div>

    <ol class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.works.steps.map((step, i) => (
          <li class="reveal relative" style={`transition-delay:${i * 70}ms`}>
            <div class="h-full rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6">
              <span
                class="flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--color-border)] font-[family-name:var(--font-display)] text-sm font-bold text-gradient"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="mt-4 font-semibold">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">{step.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
