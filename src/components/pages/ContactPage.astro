---
import ContactForm from '@components/ContactForm.astro';
import { getDict, type Locale } from '@i18n/ui';
import BaseLayout from '@layouts/BaseLayout.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<BaseLayout
  lang={lang}
  route="/contact"
  title={t.meta.contact_title}
  description={t.meta.home_desc}
>
  <section class="glow-bg relative overflow-hidden pt-32 pb-20 sm:pt-40">
    <div class="grid-pattern pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="container-x">
      <div class="mx-auto max-w-xl">
        <div class="mb-8 text-center">
          <p class="text-sm font-semibold tracking-[0.2em] text-[color:var(--color-brand-2)]">
            {t.contact.kicker}
          </p>
          <h1 class="mt-3 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
            {t.contact.title}
          </h1>
          <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.contact.subtitle}</p>
        </div>
        <ContactForm lang={lang} />
      </div>
    </div>
  </section>
</BaseLayout>
