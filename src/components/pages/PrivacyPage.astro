---
import { getDict, type Locale } from '@i18n/ui';
import BaseLayout from '@layouts/BaseLayout.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<BaseLayout
  lang={lang}
  route="/policy/privacy"
  title={t.meta.privacy_title}
  description={t.privacy.subtitle}
>
  <section class="pt-32 pb-20 sm:pt-40">
    <div class="container-x">
      <div class="mx-auto max-w-3xl">
        <h1 class="font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
          {t.privacy.title}
        </h1>
        <p class="mt-4 text-[color:var(--color-ink-muted)]">{t.privacy.subtitle}</p>

        <div class="mt-12 space-y-8">
          {
            t.privacy.body.map((sec, i) => (
              <div class="border-l-2 border-[color:var(--color-border)] pl-5">
                <h2 class="text-lg font-semibold">
                  <span class="mr-2 text-gradient">{String(i + 1).padStart(2, '0')}</span>
                  {sec.heading}
                </h2>
                <p class="mt-2 leading-relaxed text-[color:var(--color-ink-muted)]">{sec.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
