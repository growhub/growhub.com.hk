---
import BaseLayout from '@layouts/BaseLayout.astro';
import { type Locale, getDict, localizePath } from '@i18n/ui';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<BaseLayout
  lang={lang}
  route="/contact/thanks"
  title={t.meta.thanks_title}
  description={t.meta.home_desc}
>
  <section class="glow-bg relative flex min-h-[70vh] items-center overflow-hidden pt-24">
    <div class="grid-pattern pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="container-x">
      <div class="mx-auto max-w-lg text-center">
        <div
          class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)]"
        >
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="url(#svc-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </div>
        <h1 class="mt-6 font-[family-name:var(--font-display)] text-3xl font-bold tracking-tight sm:text-4xl">
          {t.thanks.title}
        </h1>
        <p class="mt-4 text-lg font-medium text-gradient">{t.thanks.subtitle}</p>
        <p class="mt-3 leading-relaxed text-[color:var(--color-ink-muted)]">{t.thanks.desc}</p>
        <a href={localizePath('/', lang)} class="btn btn-ghost mt-8">{t.thanks.back}</a>
      </div>
    </div>
  </section>

  <svg width="0" height="0" class="absolute" aria-hidden="true">
    <defs>
      <linearGradient id="svc-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#22d3ee" />
        <stop offset="100%" stop-color="#6366f1" />
      </linearGradient>
    </defs>
  </svg>
</BaseLayout>
