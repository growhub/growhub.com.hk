---
// Google Analytics 4. Enable by setting the PUBLIC_GA_ID env var
// (Measurement ID, e.g. "G-XXXXXXXXXX"). Loaded only in production builds,
// so local dev / preview without the var never sends data.
const gaId = import.meta.env.PUBLIC_GA_ID;
const enabled = Boolean(gaId) && import.meta.env.PROD;
---

{
  enabled && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )
}
