---
import type { LogoProps } from './types';

const { size = 28, class: className } = Astro.props as LogoProps;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 512 512"
  class={className}
  role="img"
  aria-label="GrowHub"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id="gh-logo-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="var(--color-brand)" />
      <stop offset="1" stop-color="var(--color-brand-2)" />
    </linearGradient>
  </defs>
  <rect width="512" height="512" rx="115" fill="url(#gh-logo-grad)"></rect>
  <g fill="none" stroke="#fff" stroke-width="48" stroke-linecap="round" stroke-linejoin="round">
    <!-- G ring + crossbar rising into an upward "growth" arrow -->
    <path d="M356 194 A122 122 0 1 0 378 256 L256 256 L256 202"></path>
    <path d="M214 240 L256 196 L298 240"></path>
  </g>
</svg>
