---
import { getDict, localizePath } from '@i18n/ui';
import LangSwitcher from '@ui/lang-switcher';
import Logo from '@ui/logo';
import MobileNav from '@ui/mobile-nav';
import { buildContactLink, buildLangLinks, buildNavLinks } from './hooks';
import type { HeaderProps } from './types';

const { lang, route } = Astro.props as HeaderProps;
const t = getDict(lang);
const home = localizePath('/', lang);
const navLinks = buildNavLinks(lang);
const contactLink = buildContactLink(lang);
const langLinks = buildLangLinks(lang, route);
---

<header id="site-header" class="fixed inset-x-0 top-0 z-30 transition-all duration-300">
  <div class="container-x">
    <div class="flex h-16 items-center justify-between">
      <a href={home} class="group flex items-center gap-2" aria-label="GrowHub home">
        <Logo size={30} />
        <span class="logo text-xl">GrowHub</span>
        <sup class="text-[10px] font-semibold text-[color:var(--color-ink-faint)]">HK</sup>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden items-center gap-7 lg:flex">
        {
          navLinks.map((l) => (
            <a
              href={l.href}
              class="text-sm font-medium text-[color:var(--color-ink-muted)] transition-colors hover:text-[color:var(--color-ink)]"
            >
              {l.label}
            </a>
          ))
        }
        <LangSwitcher lang={lang} route={route} />
        <a href={contactLink.href} class="btn btn-primary text-sm">
          {contactLink.label}
        </a>
      </nav>

      <!-- Mobile nav (React island) -->
      <MobileNav
        client:load
        links={[...navLinks, { href: home, label: t.nav.home }]}
        contact={contactLink}
        langLinks={langLinks}
      />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 12) {
      header.classList.add('is-scrolled');
    } else {
      header.classList.remove('is-scrolled');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  #site-header.is-scrolled {
    background: var(--header-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
</style>
