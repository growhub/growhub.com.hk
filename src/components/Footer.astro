---
import { type Locale, getDict, localizePath } from '@i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getDict(lang);
const year = new Date().getFullYear();

const links = [
  { href: localizePath('/', lang), label: t.footer.nav_home },
  { href: localizePath('/policy/privacy', lang), label: t.footer.nav_privacy },
  { href: localizePath('/contact', lang), label: t.footer.nav_contact },
];
---

<footer class="mt-24 border-t border-[color:var(--color-border)]">
  <div class="container-x py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href={localizePath('/', lang)} class="text-2xl font-bold tracking-tight">
          Grow<span class="text-gradient">Hub</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">
          {t.footer.tagline}
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-8 gap-y-3 text-sm">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="text-[color:var(--color-ink-muted)] transition-colors hover:text-[color:var(--color-ink)]"
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-[color:var(--color-border)] pt-6 text-xs text-[color:var(--color-ink-faint)] sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} GrowHub Limited. {t.footer.rights}</p>
      <p>Hong Kong · Software Studio</p>
    </div>
  </div>
</footer>
