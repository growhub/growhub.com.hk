---
import { getDict, localizePath } from '@i18n/ui';
import BaseLayout from '@layouts/base-layout';

const lang = 'en';
const t = getDict(lang);
---

<BaseLayout lang={lang} route="/404" title={`404 | GrowHub`} description={t.notFound.desc}>
  <section class="glow-bg relative flex min-h-[80vh] items-center overflow-hidden pt-24">
    <div class="grid-pattern pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="container-x">
      <div class="mx-auto max-w-lg text-center">
        <p class="font-[family-name:var(--font-display)] text-7xl font-bold text-gradient sm:text-8xl">
          404
        </p>
        <h1 class="mt-4 text-2xl font-bold">{t.notFound.title}</h1>
        <p class="mt-3 text-[color:var(--color-ink-muted)]">{t.notFound.desc}</p>
        <a href={localizePath('/', lang)} class="btn btn-primary mt-8">{t.notFound.back}</a>
      </div>
    </div>
  </section>
</BaseLayout>
